# Server-only lead delivery. Add these values in Vercel → Project Settings → Environment Variables.
# Never prefix private values with NEXT_PUBLIC_ and never commit a real bot token.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_TOKEN=
TELEGRAM_BOT_TOKEN=
# Numeric ID of the private chat or group that should receive website leads.
TELEGRAM_CHAT_ID=

# Internal proposal builder access.
PROPOSAL_ACCESS_CODE=
PROPOSAL_SESSION_SECRET=
